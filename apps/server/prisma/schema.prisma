generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id             String   @id @default(cuid())
  name           String
  description    String?
  persona        String?
  scenario       String?
  firstMessage   String?
  messageExample String?
  systemPrompt   String?
  rawCardJson    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
