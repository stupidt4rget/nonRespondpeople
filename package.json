{
  "name": "roleagent-tavern",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @roleagent/shared build && pnpm -r --parallel --filter \"./apps/*\" run dev",
